      "get": {
        "tags": [
          "Websites"
        ],
        "summary": "Verify website ownership using DNS TXT and HTTP fallback",
        "security": [
          {
            "apiKeyAuth": [],
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Verification result"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
