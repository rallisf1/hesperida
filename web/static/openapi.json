    "/api/v1/websites/{id}/uninvite": {
      "post": {
        "tags": [
          "Websites"
        ],
        "summary": "Remove a user's access to a website by email",
        "security": [
          {
            "apiKeyAuth": [],
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
