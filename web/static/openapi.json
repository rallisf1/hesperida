      "get": {
        "tags": [
          "Websites"
        ],
        "summary": "Get owner/member user profiles for a website",
        "security": [
          {
            "apiKeyAuth": [],
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
